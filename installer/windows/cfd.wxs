<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="*"
    Name="cFd Terminal"
    Language="1033"
    Version="1.0.0"
    Manufacturer="saarors"
    UpgradeCode="A7F3C2E1-88B4-4D5A-9F6E-123456789ABC">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perMachine"
      Description="cFd — A custom terminal shell written in C"
      Comments="No bash. No PowerShell. No wrappers. Just C." />

    <MajorUpgrade DowngradeErrorMessage="A newer version of cFd is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Simple install-dir UI (no license page so no RTF needed) -->
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <UIRef Id="WixUI_InstallDir" />
    <WixVariable Id="WixUILicenseRtf" Value="license.rtf" />

    <!-- ── Directories ── -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLFOLDER" Name="cFd" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="cFd Terminal" />
      </Directory>
    </Directory>

    <!-- ── Features ── -->
    <Feature Id="ProductFeature" Title="cFd Terminal" Level="1">
      <ComponentGroupRef Id="MainComponents" />
      <ComponentRef Id="ShortcutComp" />
      <ComponentRef Id="PathComp" />
    </Feature>

    <!-- ── Main executable ── -->
    <ComponentGroup Id="MainComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExe" Guid="B1D4A3F2-77CC-4E8B-A012-ABCDEF012345" Win64="yes">
        <File Id="cfd_exe" Source="..\..\cfd.exe" Name="cfd.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Start Menu shortcut ── -->
    <Component Id="ShortcutComp" Guid="C2E5B4A3-88DD-4F9C-B123-BCDEF1234567"
               Directory="AppMenuFolder">
      <Shortcut Id="StartMenuShortcut" Name="cFd Terminal"
                Description="cFd — A custom terminal shell"
                Target="[INSTALLFOLDER]cfd.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppMenu" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\cFd"
                     Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

    <!-- ── Add install dir to system PATH ── -->
    <Component Id="PathComp" Guid="E4A7D6C5-A0FF-4B1E-D345-DEF123456789"
               Directory="INSTALLFOLDER" KeyPath="yes" Win64="yes">
      <Environment Id="SystemPATH" Name="PATH" Value="[INSTALLFOLDER]"
                   Permanent="no" Part="last" Action="set" System="yes" />
    </Component>

  </Product>
</Wix>
